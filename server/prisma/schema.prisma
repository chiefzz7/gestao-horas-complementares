generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                     Int           @id @default(autoincrement())
  nome                   String
  email                  String        @unique
  senha                  String
  role                   String        @default("ALUNO")
  professorId            Int?
  professor              Usuario?      @relation("ProfessorAlunos", fields: [professorId], references: [id])
  alunos                 Usuario[]     @relation("ProfessorAlunos")
  certificadosEnviados   Certificado[] @relation("CertificadosAluno")
  certificadosAnalisados Certificado[] @relation("CertificadosProfessor")
}

model Grupo {
  id           Int           @id @default(autoincrement())
  numero       Int           @unique
  descricao    String        @db.Text
  horasMaximas Int
  certificados Certificado[]
}

model Certificado {
  id                  Int      @id @default(autoincrement())
  titulo              String
  horas               Int
  horasValidadas      Int?
  status              String   @default("PENDENTE")
  arquivoUrl          String
  observacaoProfessor String?  @db.Text
  dataEnvio           DateTime @default(now())
  dataAnalise         DateTime?
  alunoId             Int
  aluno               Usuario  @relation("CertificadosAluno", fields: [alunoId], references: [id])
  grupoId             Int
  grupo               Grupo    @relation(fields: [grupoId], references: [id])
  analisadoPorId      Int?
  analisadoPor        Usuario? @relation("CertificadosProfessor", fields: [analisadoPorId], references: [id])
}
